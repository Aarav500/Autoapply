class PredictionResponse(BaseModel):
    """Response model for race predictions."""
    race_id: str
    model_name: str
    win_prob: dict[str, float]      # Driver -> probability
    podium_prob: dict[str, float]   # Driver -> probability
    expected_finish: dict[str, float]
