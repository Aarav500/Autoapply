## Appendix B: Additional Technical Details

### Environment Configuration (25+ Settings)

```python
class Settings(BaseSettings):
    # Environment
    env: str = Field(default="local")
    
    # API
    api_host: str = Field(default="0.0.0.0")
    api_port: int = Field(default=8000)
    
    # Data Storage
    data_dir: str = Field(default="./data")
    model_dir: str = Field(default="./models")
    
    # ML Configuration
    random_seed: int = Field(default=42)
    n_jobs: int = Field(default=-1)
    optuna_n_trials: int = Field(default=100)
    
    # Feature Engineering
    enable_feature_selection: bool = Field(default=True)
    feature_importance_threshold: float = Field(default=0.01)
    
    # Backtesting
    backtest_start_year: int = Field(default=2022)
    backtest_end_year: int = Field(default=2024)
```

### Probability Calibration Pipeline (330 lines)

```python
class ProbabilityCalibrator:
    """Calibrator supporting isotonic and sigmoid (Platt) methods."""
    
    def __init__(self, method: str = "isotonic"):
        if method == "isotonic":
            self.calibrator = IsotonicRegression(out_of_bounds="clip")
        elif method == "sigmoid":
            self.calibrator = LogisticRegression()  # Platt scaling
    
    def fit(self, scores: np.ndarray, true_outcomes: np.ndarray):
        self.calibrator.fit(scores, true_outcomes)
    
    def transform(self, scores: np.ndarray) -> np.ndarray:
        return self.calibrator.transform(scores)
```

### S3 Cloud Storage (255 lines)

```python
class S3Storage:
    """Cloud storage for model artifacts and reports.
    
    Supports:
    - Model artifact upload/download with versioning
    - Report storage with timestamps
    - Lazy boto3 client initialization
    """
    
    def upload_model_artifact(self, model_path, model_name, version="latest"):
        s3_key = f"models/{model_name}/{version}/{model_path.name}"
        return self.upload_file(model_path, s3_key)
```

### Singleton Caching (94 lines)

```python
class ModelCache:
    """Singleton cache for loaded models - avoids reloading on each request."""
    _instance = None
    _models: dict[str, Any] = {}
    
    def get_model(self, model_name: str, model_dir: Path, task: str = "win"):
        cache_key = f"{model_name}_{task}"
        if cache_key not in self._models:
            self._models[cache_key] = ModelRegistry.load_model(...)
        return self._models[cache_key]

class DataCache:
    """Singleton cache for feature data - loaded once at startup."""
    _features: Optional[pd.DataFrame] = None
```

