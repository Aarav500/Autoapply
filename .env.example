# ========================================
# AutoApply - Environment Variables
# ========================================
# Copy to .env.local for local development
# For production, configure these as GitHub Secrets

# ========================================
# DATABASE (PostgreSQL)
# ========================================
DATABASE_URL="postgresql://user:password@localhost:5432/autoapply?schema=public"

# ========================================
# AUTHENTICATION (NextAuth.js)
# ========================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-32-char-secret-here"

# Google OAuth (optional - for Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ========================================
# AI - Claude/Anthropic
# ========================================
# Use either CLAUDE_API_KEY or ANTHROPIC_API_KEY (both work)
CLAUDE_API_KEY=""
# ANTHROPIC_API_KEY=""  # Alternative key name

# ========================================
# AWS S3 (Document Storage)
# ========================================
# Used for: resumes, cover letters, profile documents
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME="autoapply-documents"

# ========================================
# EMAIL - SendGrid (Outbound)
# ========================================
# Used for: application confirmations, interview reminders, notification digests
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@yourdomain.com"

# ========================================
# EMAIL - Gmail API (Inbox Monitoring)
# ========================================
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI="http://localhost:3000/api/auth/callback/gmail"

# ========================================
# NOTIFICATIONS - Twilio (SMS & WhatsApp)
# ========================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""  # Recommended for production
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"  # Fallback if no messaging service

# ========================================
# CALENDAR - Google Calendar (Optional)
# ========================================
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""

# ========================================
# LINKEDIN (Optional - for profile sync)
# ========================================
LINKEDIN_EMAIL=""
LINKEDIN_PASSWORD=""
# Note: LinkedIn scraping may violate ToS. Use official API when possible.

# ========================================
# GITHUB API (Optional - for portfolio)
# ========================================
GITHUB_TOKEN=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ========================================
# APP URL (for email links)
# ========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ========================================
# MONITORING (Optional)
# ========================================
SENTRY_DSN=""
POSTHOG_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ========================================
# FEATURE FLAGS
# ========================================
ENABLE_AUTO_APPLY="false"
ENABLE_EMAIL_SYNC="false"
ENABLE_JOB_SCRAPING="true"

# ========================================
# RATE LIMITING
# ========================================
MAX_APPLICATIONS_PER_DAY="25"
MAX_EMAILS_PER_HOUR="10"
JOB_SCRAPE_INTERVAL_HOURS="6"
