# Environment Variables Template
# Copy to .env.local for local development
# For production: Use GitHub Secrets

# ========================================
# CLAUDE API (REQUIRED)
# Get from: https://console.anthropic.com
# ========================================
CLAUDE_API_KEY=sk-ant-api03-xxxxx
NEXT_PUBLIC_CLAUDE_API_KEY=sk-ant-api03-xxxxx

# ========================================
# AWS CREDENTIALS
# Get from: AWS IAM Console
# ========================================
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-west-2

# ========================================
# S3 BUCKET
# Create in AWS S3 Console
# ========================================
S3_BUCKET_NAME=college-essay-app-bucket

# ========================================
# DATABASE (PostgreSQL)
# Options:
# - AWS RDS PostgreSQL
# - Supabase (free tier)
# - Neon (free tier)
# - PlanetScale (MySQL alternative)
# ========================================
DATABASE_URL=postgresql://user:password@host:5432/database

# ========================================
# OPTIONAL: Feature Flags
# ========================================
NEXT_PUBLIC_ENABLE_JOB_HUB=true
NEXT_PUBLIC_ENABLE_AUTO_APPLY=true
NEXT_PUBLIC_DEBUG_MODE=false

# ========================================
# Model Configuration
# ========================================
# Essays: claude-3-opus-20240229 (best quality)
# Reviews: claude-3-5-sonnet-20241022 (fast + good)
# Quick tasks: claude-3-haiku-20240307 (fastest)
CLAUDE_ESSAY_MODEL=claude-3-opus-20240229
CLAUDE_REVIEW_MODEL=claude-3-5-sonnet-20241022
CLAUDE_QUICK_MODEL=claude-3-haiku-20240307
